# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environments
venv/
.venv/
env/
ENV/

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
.eggs/
wheels/
pip-wheel-metadata/

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# --- Testing & coverage ---
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/

# --- Type checkers ---
.mypy_cache/
.pyre/
.pytype/
.ruff_cache/

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb_checkpoints

# --- IDE / editor ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# --- Environment / secrets ---
.env
.env.local
.env.*.local
*.pem
*.key

# --- Logs ---
*.log
logs/

# --- ML model artifacts (large binary checkpoints) ---
# Comment these out if you want to commit specific checkpoints.
models/saved/*.pt
models/saved/*.pth
models/saved/*.ckpt
# Pickled scalers/encoders are small enough to commit, so they're allowed.

# --- Data ---
# Raw scraped data and large processed CSVs are excluded by default.
# Comment out if you want them tracked.
data/raw/*.csv
data/processed/*.csv

# --- Node (in case the frontend ever adds tooling) ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
models/saved/*.pkl
models/saved/*.pt
models/saved/*.pkl
models/saved/*.pt
